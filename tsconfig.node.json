{
    "compilerOptions": {
        "composite": true,
        "skipLibCheck": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@public/*": ["./public/*"],
            "@package.json": ["./package.json"]
        }
    },
    "include": ["vite.config.ts"]
}
